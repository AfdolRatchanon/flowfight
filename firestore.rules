rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====

    function currentUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student');
    }

    function isAdmin() {
      return request.auth != null && currentUserRole() == 'admin';
    }

    function isTeacherOrAdmin() {
      return request.auth != null && currentUserRole() in ['teacher', 'admin'];
    }

    // ===== Users =====
    match /users/{userId} {
      // เจ้าของอ่านได้เสมอ, teacher/admin อ่าน list ได้ (ดู progress นักเรียน)
      // student ไม่สามารถ list ข้อมูลของผู้ใช้อื่นได้ (privacy)
      allow get:  if request.auth != null && (request.auth.uid == userId || isTeacherOrAdmin());
      allow list: if isTeacherOrAdmin();

      // create — รองรับ registerTeacher (setDoc พร้อม role:'teacher' บน doc ใหม่)
      allow create: if request.auth != null && request.auth.uid == userId;

      // update — เจ้าของเท่านั้น
      // role เปลี่ยนได้เฉพาะ student → teacher เท่านั้น
      // ป้องกัน: ใคร ๆ ก็ไม่สามารถ self-escalate ไปเป็น admin ผ่าน client ได้
      // (admin ต้องตั้งใน Firebase Console เท่านั้น)
      allow update: if request.auth != null && request.auth.uid == userId
        && (
          // ไม่แตะ role field เลย — ปลอดภัยที่สุด
          !request.resource.data.keys().hasAny(['role'])
          // หรือ student → teacher เท่านั้น (ผ่าน invite code ที่ตรวจแล้วจาก client)
          || (resource.data.get('role', 'student') == 'student'
              && request.resource.data.role == 'teacher')
        );

      // Flowchart Save/Load — เจ้าของเท่านั้น
      match /flowcharts/{levelId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ===== Teacher Invite Codes =====
    // get เดี่ยว: ทุก auth user ตรวจสอบ code ได้ (สำหรับ upgradeToTeacher)
    // list: admin เท่านั้น ป้องกัน student scan หา unused codes
    match /teacher_codes/{code} {
      allow get:  if request.auth != null;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== Classrooms =====
    match /classrooms/{roomCode} {
      // get เดี่ยว: ทุก auth user (นักเรียน join ด้วย roomCode)
      // list: teacher/admin เท่านั้น ป้องกัน student เห็นห้องเรียนทุกห้อง
      allow get:  if request.auth != null;
      allow list: if isTeacherOrAdmin();

      // create — เฉพาะ teacher หรือ admin เท่านั้น (ป้องกัน student สร้างห้องเอง)
      allow create: if request.auth != null
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'roomCode','teacherId','teacherName','className','students','createdAt'
        ])
        && isTeacherOrAdmin();

      allow update: if request.auth != null && (
        // ครู/admin เจ้าของห้องแก้ได้ทุกอย่าง
        resource.data.teacherId == request.auth.uid
        // นักเรียน join — เพิ่มตัวเองใน students เท่านั้น
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['students'])
            && request.resource.data.students.hasAll(resource.data.students))
      );
    }

    // ===== Assignments =====
    // ทุก auth user อ่านได้ — นักเรียนต้องใช้ getDocs(query(...where classroomCode))
    // data ไม่มี PII (แค่ levelIds, deadline, title) — acceptable
    match /assignments/{assignmentId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.teacherId == request.auth.uid
        && isTeacherOrAdmin()
        && request.resource.data.keys().hasOnly([
          'id','classroomCode','teacherId','title','levelIds','deadline','createdAt'
        ])
        && request.resource.data.levelIds.size() > 0
        && request.resource.data.levelIds.size() <= 20
        && request.resource.data.deadline is int
        && request.resource.data.deadline > request.time.toMillis()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;

      allow delete: if request.auth != null
        && (resource.data.teacherId == request.auth.uid || isAdmin());
    }

    // ===== Custom Levels (Teacher-created) =====
    match /customLevels/{levelId} {
      // อ่าน: auth ทุกคน (นักเรียนต้องอ่านเพื่อเล่น)
      allow read: if request.auth != null;

      // สร้าง: teacher/admin เท่านั้น และต้องเป็น createdBy ตัวเอง
      allow create: if request.auth != null
        && isTeacherOrAdmin()
        && request.resource.data.createdBy == request.auth.uid;

      // แก้ไข/ลบ: เจ้าของ (teacher) หรือ admin เท่านั้น
      allow update, delete: if request.auth != null
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ===== Classroom Leaderboard (Class Competition) =====
    // subcollection: classroomBoards/{roomCode}/members/{uid}
    match /classroomBoards/{roomCode}/members/{uid} {
      // อ่าน: ทุก auth user (นักเรียนในห้องดูอันดับเพื่อนได้)
      allow read: if request.auth != null;

      // เขียน: เจ้าของ entry เท่านั้น, validate fields ครบ
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.classroomCode == roomCode
        && request.resource.data.keys().hasOnly([
          'uid', 'name', 'levelsCompleted', 'avgScore', 'totalXP', 'classroomCode', 'updatedAt'
        ])
        && request.resource.data.levelsCompleted is int
        && request.resource.data.levelsCompleted >= 0
        && request.resource.data.avgScore is int
        && request.resource.data.avgScore >= 0
        && request.resource.data.avgScore <= 100
        && request.resource.data.totalXP is int
        && request.resource.data.totalXP >= 0;
    }

    // ===== Overall Leaderboard =====
    // docId = playerId
    match /leaderboards/{playerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == playerId
        && request.resource.data.playerId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'playerId','playerName','characterName','characterClass','characterLevel',
          'experience','levelReached','levelsCompleted',
          'totalKills','totalPlayTime','totalDamageDealt','totalDamageTaken',
          'gameMode','lastUpdated',
          'campaignStartedAt','campaignClearedAt','campaignTotalTimeMs'
        ])
        && (request.resource.data.get('characterLevel', 1) >= 1)
        && (request.resource.data.get('characterLevel', 1) <= 10)
        && (request.resource.data.get('totalKills', 0) >= 0)
        && (request.resource.data.get('totalKills', 0) <= 99999)
        && (request.resource.data.get('totalDamageDealt', 0) >= 0)
        && (request.resource.data.get('totalDamageDealt', 0) <= 999999999)
        && (request.resource.data.get('totalPlayTime', 0) >= 0)
        && (request.resource.data.get('totalPlayTime', 0) <= 864000000); // max 10 days ms
    }

    // ===== Per-level Leaderboard =====
    // docId = levelId_playerId
    match /levelboards/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.playerId == request.auth.uid
        && request.resource.data.won == true
        && request.resource.data.keys().hasOnly([
          'levelId','levelNumber','playerId','won',
          'playerName','characterName','characterClass','characterLevel',
          'timeMs','damageDealt','damageTaken','heroHPRemaining','heroHPPercent',
          'timestamp'
        ])
        && (request.resource.data.get('timeMs', 0) >= 0)
        && (request.resource.data.get('timeMs', 0) <= 3600000)
        && (request.resource.data.get('damageDealt', 0) >= 0)
        && (request.resource.data.get('damageTaken', 0) >= 0)
        && (request.resource.data.get('characterLevel', 1) >= 1)
        && (request.resource.data.get('characterLevel', 1) <= 10);
    }

    // ===== Endless Mode Leaderboard =====
    // docId = playerId
    match /endlessboards/{playerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == playerId
        && request.resource.data.playerId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'playerId','playerName','characterName','characterClass','characterLevel',
          'score','wavesCleared',
          'totalDamageDealt','totalDamageTaken',
          'timestamp'
        ])
        && (request.resource.data.get('score', 0) >= 0)
        && (request.resource.data.get('score', 0) <= 999999)
        && (request.resource.data.get('wavesCleared', 0) >= 0)
        && (request.resource.data.get('wavesCleared', 0) <= 9999);
    }
  }
}
